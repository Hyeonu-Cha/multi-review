#!/usr/bin/env bash
#
# multi-review — fan a PR diff to several AI-CLI reviewers, each running as a real
# INTERACTIVE CLI in its own pane (using its native code-review skill), then reconcile
# their findings into one review.
#
# Each reviewer is launched interactively in a pane; the orchestrator sends it an
# instruction (via the pane) telling it to review the diff and WRITE its JSON findings
# to a file. A final headless reconcile pass merges those files into one review.
#
# Usage:
#   multi-review [PR_NUMBER]                 review a GitHub PR (via gh)
#   multi-review --diff path/to.patch        review a saved diff
#   multi-review --base origin/main          review current branch vs base (default)
#
# Options:
#   --reviewers a,b,c   override the enabled reviewers from config
#   --reconciler NAME   override the reconciler CLI name (must exist in config)
#   --backend B         pane backend: auto|wezterm|tmux  (default: auto)
#   --post              post the final review to the PR (needs PR_NUMBER + gh)
#   --timeout SECONDS   per-run wait for reviewers to write their JSON (default 900)
#
# Backends (interactive reviewers need a pane multiplexer):
#   wezterm — native Windows. Run this FROM INSIDE a WezTerm window.
#   tmux    — Linux/WSL. One tmux pane per reviewer.
#
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CONFIG="$ROOT/config/reviewers.json"
REVIEW_PROMPT="$ROOT/prompts/review.md"
RECONCILE_PROMPT="$ROOT/lib/reconcile.md"
START_DIR="$(pwd)"

die() { echo "multi-review: $*" >&2; exit 1; }
need() { command -v "$1" >/dev/null 2>&1 || die "required tool not found: $1"; }

# Windows jq emits CRLF; strip CR so values feeding shell vars don't carry \r.
jqr() { jq "$@" | tr -d '\r'; }
# Windows path (forward-slash, no escaping) for handing file paths to Windows CLIs.
winpath() { cygpath -m "$1" 2>/dev/null || echo "$1"; }

need jq

# ---- parse args -------------------------------------------------------------
PR=""; DIFF_FILE=""; BASE="origin/main"
REVIEWERS_OVERRIDE=""; RECONCILER_OVERRIDE=""; POST=0; TIMEOUT=900; BACKEND="auto"
while [ $# -gt 0 ]; do
  case "$1" in
    --diff)       DIFF_FILE="$2"; shift 2;;
    --base)       BASE="$2"; shift 2;;
    --reviewers)  REVIEWERS_OVERRIDE="$2"; shift 2;;
    --reconciler) RECONCILER_OVERRIDE="$2"; shift 2;;
    --backend)    BACKEND="$2"; shift 2;;
    --post)       POST=1; shift;;
    --timeout)    TIMEOUT="$2"; shift 2;;
    -h|--help)    sed -n '2,30p' "$0"; exit 0;;
    -*)           die "unknown option: $1";;
    *)            PR="$1"; shift;;
  esac
done

[ -f "$CONFIG" ] || die "missing config: $CONFIG"

# ---- backend detection ------------------------------------------------------
WEZTERM_BIN="$(command -v wezterm || true)"
[ -z "$WEZTERM_BIN" ] && [ -x "/c/Program Files/WezTerm/wezterm" ] && WEZTERM_BIN="/c/Program Files/WezTerm/wezterm"

wez() { MSYS2_ARG_CONV_EXCL='*' "$WEZTERM_BIN" cli --no-auto-start "$@"; }
wez_ok() { [ -n "$WEZTERM_BIN" ] && wez list >/dev/null 2>&1; }

if [ "$BACKEND" = "auto" ]; then
  if wez_ok; then BACKEND="wezterm"
  elif command -v tmux >/dev/null 2>&1; then BACKEND="tmux"
  else die "no interactive backend: start a WezTerm window (Windows) or install tmux (Linux/WSL)"; fi
fi
case "$BACKEND" in
  wezterm) wez_ok || die "wezterm backend: no running WezTerm instance reachable — run this from inside a WezTerm window";;
  tmux)    need tmux;;
  *)       die "unknown/unsupported backend: $BACKEND (use wezterm or tmux)";;
esac

# ---- per-run workspace ------------------------------------------------------
RUN="$ROOT/out/$(date +%Y%m%d-%H%M%S)"
mkdir -p "$RUN"
DIFF="$RUN/diff.patch"
PROMPT="$RUN/prompt.md"
FINAL="$RUN/review.json"

# ---- obtain the diff --------------------------------------------------------
if [ -n "$DIFF_FILE" ]; then
  cp "$DIFF_FILE" "$DIFF"
elif [ -n "$PR" ]; then
  need gh
  gh pr diff "$PR" > "$DIFF"
else
  git rev-parse --verify "$BASE" >/dev/null 2>&1 \
    || die "base ref '$BASE' not found (use --base or pass a PR number)"
  git diff "$BASE"...HEAD > "$DIFF"
fi
[ -s "$DIFF" ] || die "diff is empty — nothing to review"

# ---- build the criteria+schema file the agents read -------------------------
# (review.md = criteria + STRICT JSON schema; the diff is appended for convenience)
cat "$REVIEW_PROMPT" "$DIFF" > "$PROMPT"

# ---- resolve reviewer set ---------------------------------------------------
if [ -n "$REVIEWERS_OVERRIDE" ]; then
  mapfile -t NAMES < <(echo "$REVIEWERS_OVERRIDE" | tr ',' '\n' | sed '/^$/d')
else
  mapfile -t NAMES < <(jqr -r '.reviewers[] | select(.enabled) | .name' "$CONFIG")
fi
[ "${#NAMES[@]}" -gt 0 ] || die "no reviewers selected"

RECONCILER="${RECONCILER_OVERRIDE:-$(jqr -r '.reconciler.name // "claude"' "$CONFIG")}"
launch_for() { jqr -r --arg n "$1" '.reviewers[] | select(.name==$n) | .launch' "$CONFIG"; }
wait_for()   { jqr -r --arg n "$1" '.reviewers[] | select(.name==$n) | (.ready_wait // 8)' "$CONFIG"; }
INSTRUCTION_TMPL="$(jqr -r '.instruction' "$CONFIG")"
[ -n "$INSTRUCTION_TMPL" ] && [ "$INSTRUCTION_TMPL" != "null" ] || die "config has no 'instruction'"

# instruction with file paths substituted (Windows paths for the Windows CLIs)
instr_for() {
  local name="$1" out="$RUN/$1.json" s="$INSTRUCTION_TMPL"
  s="${s//\{DIFF\}/$(winpath "$DIFF")}"
  s="${s//\{PROMPT\}/$(winpath "$PROMPT")}"
  s="${s//\{OUT\}/$(winpath "$out")}"
  printf '%s' "$s"
}

echo "› backend: $BACKEND    reviewers: ${NAMES[*]}    reconciler: $RECONCILER"
echo "› diff: $(wc -l < "$DIFF") lines    workspace: $RUN"

# ---- launch interactive reviewers + send them the instruction ---------------
declare -A PANES=()      # name -> pane/window id
TMUX_SESSION=""

launch_wezterm() {
  local bash_win anchor newpane launch maxwait=0 w
  bash_win="$(cygpath -w "$(command -v bash)")"
  anchor="${WEZTERM_PANE:-}"
  [ -z "$anchor" ] && anchor="$(wez list --format json 2>/dev/null | jqr -r '.[0].pane_id // empty')"
  [ -n "$anchor" ] || die "wezterm: could not determine a target pane (run from inside WezTerm)"
  # spawn one interactive pane per reviewer
  for name in "${NAMES[@]}"; do
    launch="$(launch_for "$name")"
    [ -n "$launch" ] && [ "$launch" != "null" ] || die "no 'launch' configured for reviewer '$name'"
    newpane="$(wez split-pane --pane-id "$anchor" -- "$bash_win" -lc "cd '$START_DIR'; exec $launch")"
    [ -n "$newpane" ] || die "wezterm: failed to spawn pane for '$name'"
    PANES["$name"]="$newpane"; anchor="$newpane"
    w="$(wait_for "$name")"; [ "$w" -gt "$maxwait" ] 2>/dev/null && maxwait="$w"
  done
  echo "› spawned ${#NAMES[@]} panes; letting CLIs boot (${maxwait}s)…"
  sleep "$maxwait"
  # send each reviewer its instruction, then Enter to submit
  for name in "${NAMES[@]}"; do
    wez send-text --pane-id "${PANES[$name]}" --no-paste "$(instr_for "$name")"
    wez send-text --pane-id "${PANES[$name]}" --no-paste $'\r'
  done
  echo "› instructions sent to all reviewers"
}

launch_tmux() {
  local launch maxwait=0 w
  TMUX_SESSION="mreview-$$"
  local first="${NAMES[0]}"
  tmux new-session -d -s "$TMUX_SESSION" -n review "cd '$START_DIR'; exec $(launch_for "$first")"
  PANES["$first"]="$TMUX_SESSION:0.0"
  local idx=0
  for name in "${NAMES[@]:1}"; do
    idx=$((idx+1))
    launch="$(launch_for "$name")"
    tmux split-window -t "$TMUX_SESSION" "cd '$START_DIR'; exec $launch"
    tmux select-layout -t "$TMUX_SESSION" tiled >/dev/null
    PANES["$name"]="$TMUX_SESSION:0.$idx"
  done
  for name in "${NAMES[@]}"; do w="$(wait_for "$name")"; [ "$w" -gt "$maxwait" ] 2>/dev/null && maxwait="$w"; done
  echo "› tmux session '$TMUX_SESSION' (attach: tmux attach -t $TMUX_SESSION); booting (${maxwait}s)…"
  sleep "$maxwait"
  for name in "${NAMES[@]}"; do
    tmux send-keys -t "${PANES[$name]}" "$(instr_for "$name")" Enter
  done
  echo "› instructions sent to all reviewers"
}

case "$BACKEND" in
  wezterm) launch_wezterm;;
  tmux)    launch_tmux;;
esac

# ---- wait for each reviewer to write valid JSON -----------------------------
echo -n "› waiting for reviewers to write findings"
elapsed=0
while :; do
  done_count=0
  for name in "${NAMES[@]}"; do
    jqr -e . "$RUN/$name.json" >/dev/null 2>&1 && done_count=$((done_count+1))
  done
  [ "$done_count" -ge "${#NAMES[@]}" ] && break
  [ "$elapsed" -ge "$TIMEOUT" ] && { echo " timeout"; break; }
  sleep 5; elapsed=$((elapsed+5)); echo -n "."
done
echo " ($done_count/${#NAMES[@]} produced valid JSON)"

# ---- close reviewer panes ---------------------------------------------------
if [ "$BACKEND" = "wezterm" ]; then
  for name in "${NAMES[@]}"; do wez kill-pane --pane-id "${PANES[$name]}" >/dev/null 2>&1 || true; done
elif [ "$BACKEND" = "tmux" ] && [ -n "$TMUX_SESSION" ]; then
  tmux kill-session -t "$TMUX_SESSION" 2>/dev/null || true
fi

# ---- assemble reconcile input -----------------------------------------------
RECON_IN="$RUN/_reconcile_input.md"
cat "$RECONCILE_PROMPT" > "$RECON_IN"
got=0
for name in "${NAMES[@]}"; do
  f="$RUN/$name.json"
  if jqr -e . "$f" >/dev/null 2>&1; then
    { echo; echo "### reviewer: $name"; cat "$f"; echo; } >> "$RECON_IN"
    got=$((got+1))
  else
    echo "  ! $name produced no valid JSON — watch its pane / check $f" >&2
  fi
done
[ "$got" -gt 0 ] || die "no reviewer produced valid JSON — check $RUN/*.json"

# ---- reconcile (headless) ---------------------------------------------------
RTMPL="$(jqr -r '.reconciler.cmd' "$CONFIG")"
[ -n "$RTMPL" ] && [ "$RTMPL" != "null" ] || die "config has no reconciler.cmd"
rcmd="${RTMPL//\{PROMPT\}/$RECON_IN}"; rcmd="${rcmd//\{OUT\}/$FINAL}"
echo "› reconciling $got reviews with $RECONCILER"
bash -c "$rcmd" >/dev/null

jqr -e . "$FINAL" >/dev/null 2>&1 || die "reconciler output is not valid JSON: $FINAL"

echo
echo "================ COMBINED REVIEW ================"
jqr -r '.body, "",
  "Verdict: \(.event)   (\(.comments | length) inline comment(s))", "",
  (.comments[] | "• \(.path):\(.line) [\(.side)]\n\(.body)\n")' "$FINAL"
echo "================================================"
echo "› saved: $FINAL"

# ---- optional post ----------------------------------------------------------
if [ "$POST" -eq 1 ]; then
  [ -n "$PR" ] || die "--post requires a PR number"
  need gh
  read -r OWNER REPO < <(gh repo view --json owner,name -q '.owner.login + " " + .name' | tr -d '\r')
  [ -n "$OWNER" ] && [ -n "$REPO" ] || die "could not resolve owner/repo via gh"
  gh api "repos/$OWNER/$REPO/pulls/$PR/reviews" --input "$FINAL" >/dev/null
  echo "› posted review to $OWNER/$REPO #$PR (inline comments via reviews API)"
fi
